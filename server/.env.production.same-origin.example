PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bugSense
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
CORS_ORIGIN=https://bugsense.com
SALT_ROUNDS=10
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
FRONTEND_URL=https://bugsense.com
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://bugsense.com/api/v1/users/auth/google/callback
